# Frontend base URL (no trailing slash)
RHOMBUS_BASE_URL=https://rhombusai.com

# Backend API base URL (no trailing slash)
RHOMBUS_API_URL=https://api.rhombusai.com

# Login credentials for the test account
RHOMBUS_EMAIL=
RHOMBUS_PASSWORD=

# (Optional) Reuse an existing project instead of creating a new one each run.
# Free plan allows only 3 projects. Set this to the numeric ID visible in the
# browser URL bar when you open any project: https://rhombusai.com/workflow/{id}
# Leave blank to let the tests auto-create a project (fails if at the plan limit).
RHOMBUS_TEST_PROJECT_ID=
