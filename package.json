{
  "name": "rhombus-qa",
  "version": "1.0.0",
  "description": "Automated QA suite for Rhombus AI (SDET take-home exercise)",
  "private": true,
  "scripts": {
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:all": "playwright test",
    "lint": "eslint \"ui-tests/**/*.ts\" \"api-tests/**/*.ts\" \"shared/**/*.ts\" \"playwright.config.ts\" --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "python -m pytest data-validation/ -v"
  },
  "devDependencies": {
    "@playwright/test": "1.55.1",
    "@types/node": "20.14.2",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "dotenv": "16.4.5",
    "eslint": "8.57.0",
    "eslint-plugin-playwright": "1.6.2",
    "prettier": "3.3.2",
    "typescript": "5.4.5"
  }
}
